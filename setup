#!/usr/bin/env bash
set -euo pipefail

# Ultimate SDLC Framework — Claude Code Plugin Setup
# Installs the framework as a proper Claude Code plugin.
# Source repo is NOT the install target — files are copied to the plugin cache.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AG_HOME="$HOME/.ultimate-sdlc"
CLAUDE_DIR="$HOME/.claude"
AGENTS_DIR="$CLAUDE_DIR/agents"
RULES_DIR="$CLAUDE_DIR/rules/ultimate-sdlc"

MARKETPLACE="ultimate-sdlc"
PLUGIN_ID="ultimate-sdlc@${MARKETPLACE}"
PLUGIN_VERSION="3.1.0"
PLUGIN_CACHE="$CLAUDE_DIR/plugins/cache/${MARKETPLACE}/ultimate-sdlc/$PLUGIN_VERSION"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${BLUE}[info]${NC}  $*"; }
ok()    { echo -e "${GREEN}[ok]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[warn]${NC}  $*"; }
error() { echo -e "${RED}[error]${NC} $*"; }

echo ""
echo -e "${BOLD}Ultimate SDLC Framework — Claude Code Plugin Setup${NC}"
echo "======================================================"
echo ""

# ── Check prerequisites ──────────────────────────────────────────────
if ! command -v claude &>/dev/null; then
    warn "Claude Code CLI not found in PATH. The plugin will be installed but requires Claude Code to function."
fi

# ── Check if already installed ───────────────────────────────────────
if [[ -d "$PLUGIN_CACHE" ]]; then
    warn "Ultimate SDLC is already installed at $PLUGIN_CACHE"
    read -rp "Re-install? This will overwrite the installed copy. [y/N] " answer
    if [[ "${answer,,}" != "y" ]]; then
        echo "Aborted."
        exit 0
    fi
    rm -rf "$PLUGIN_CACHE"
fi

# ── Naming mode selection ────────────────────────────────────────────
echo "Select naming mode for workflow commands:"
echo ""
echo "  1) ${BOLD}Namespaced names${NC} (default, recommended)"
echo "     /sdlc-init, /sdlc-planning-start, /sdlc-dev-wave-1, /sdlc-continue, etc."
echo ""
echo "  2) ${BOLD}Short names${NC}"
echo "     /init, /planning-start, /dev-wave-1, /continue, etc."
echo ""
read -rp "Choice [1/2]: " naming_choice

NAMING_MODE="namespaced"
if [[ "${naming_choice}" == "2" ]]; then
    NAMING_MODE="short"
fi

info "Naming mode: ${BOLD}${NAMING_MODE}${NC}"
echo ""

# ── Create ~/.ultimate-sdlc/ config ──────────────────────────────────
info "Creating $AG_HOME/ ..."
mkdir -p "$AG_HOME"/{analytics,sessions}

cat > "$AG_HOME/config.yaml" <<EOF
# Ultimate SDLC Framework — Global Config
naming_mode: ${NAMING_MODE}
governance_mode: standard
project_type: web-app
telemetry: off
proactive: true
source_repo: ${SCRIPT_DIR}
EOF
ok "Config written to $AG_HOME/config.yaml"

# ── Copy source to plugin cache ──────────────────────────────────────
info "Installing to plugin cache: $PLUGIN_CACHE ..."
mkdir -p "$PLUGIN_CACHE"

# Copy all framework files to the plugin cache (excluding .git)
rsync -a --exclude='.git' "$SCRIPT_DIR/" "$PLUGIN_CACHE/"
ok "Copied framework to plugin cache"

# ── Make bin/ scripts executable ─────────────────────────────────────
chmod +x "$PLUGIN_CACHE/bin/"* 2>/dev/null || true

# ── Patch skill names based on naming mode ───────────────────────────
if [[ -x "$PLUGIN_CACHE/bin/sdlc-patch-names" ]]; then
    info "Patching skill names for ${NAMING_MODE} mode ..."
    # Temporarily update config path for the patch script
    SDLC_CONFIG="$AG_HOME/config.yaml" "$PLUGIN_CACHE/bin/sdlc-patch-names"
    ok "Skill names patched"
fi

# ── Clean old installations ──────────────────────────────────────────
info "Cleaning old installations ..."
CLEANED=0
# Remove old hard-linked skill directories from previous install method
for link in "$CLAUDE_DIR/skills"/sdlc-*/; do
    [[ -d "${link%/}" ]] || continue
    if [[ -f "${link%/}/SKILL.md" ]] && [[ "$(basename "${link%/}")" == sdlc-* ]]; then
        # Don't remove the source repo if it happens to be under skills/
        [[ "${link%/}" == "$SCRIPT_DIR" ]] && continue
        rm -rf "${link%/}"
        CLEANED=$((CLEANED + 1))
    fi
done
[[ $CLEANED -gt 0 ]] && info "Removed $CLEANED old skill directory installation(s)"

# ── Register as Claude Code plugin ──────────────────────────────────
info "Registering as Claude Code plugin ..."
PLUGINS_DIR="$CLAUDE_DIR/plugins"
INSTALLED_PLUGINS="$PLUGINS_DIR/installed_plugins.json"
NOW="$(date -u +%Y-%m-%dT%H:%M:%S.000Z)"

mkdir -p "$PLUGINS_DIR"

# Ensure installed_plugins.json exists
if [[ ! -f "$INSTALLED_PLUGINS" ]]; then
    echo '{"version":2,"plugins":{}}' > "$INSTALLED_PLUGINS"
fi

# Add/update plugin entry — installPath points to the CACHE copy, not the source
python3 -c "
import json
with open('$INSTALLED_PLUGINS', 'r') as f:
    data = json.load(f)
if 'plugins' not in data:
    data['plugins'] = {}
data['plugins']['$PLUGIN_ID'] = [{
    'scope': 'user',
    'installPath': '$PLUGIN_CACHE',
    'version': '$PLUGIN_VERSION',
    'installedAt': '$NOW',
    'lastUpdated': '$NOW'
}]
with open('$INSTALLED_PLUGINS', 'w') as f:
    json.dump(data, f, indent=2)
"
ok "Registered plugin: $PLUGIN_ID"

# Enable plugin in settings.json
SETTINGS="$CLAUDE_DIR/settings.json"
if [[ ! -f "$SETTINGS" ]]; then
    echo '{}' > "$SETTINGS"
fi
python3 -c "
import json
with open('$SETTINGS', 'r') as f:
    data = json.load(f)
if 'enabledPlugins' not in data:
    data['enabledPlugins'] = {}
data['enabledPlugins']['$PLUGIN_ID'] = True
with open('$SETTINGS', 'w') as f:
    json.dump(data, f, indent=2)
"
ok "Enabled plugin in settings.json"

# Create marketplace directory (real dir with .claude-plugin/ metadata, like other plugins)
MARKETPLACE_DIR="$PLUGINS_DIR/marketplaces/$MARKETPLACE"
mkdir -p "$MARKETPLACE_DIR"
# Copy the full plugin into the marketplace dir (this is how Claude Code expects it)
rsync -a --exclude='.git' "$PLUGIN_CACHE/" "$MARKETPLACE_DIR/"

# Register marketplace in known_marketplaces.json
MARKETPLACES_JSON="$PLUGINS_DIR/known_marketplaces.json"
if [[ ! -f "$MARKETPLACES_JSON" ]]; then
    echo '{}' > "$MARKETPLACES_JSON"
fi
python3 -c "
import json
with open('$MARKETPLACES_JSON', 'r') as f:
    data = json.load(f)
data['$MARKETPLACE'] = {
    'source': {
        'source': 'github',
        'repo': 'UnpaidAttention/claude-code-ultimate-sdlc-framework'
    },
    'installLocation': '$MARKETPLACE_DIR',
    'lastUpdated': '$NOW'
}
with open('$MARKETPLACES_JSON', 'w') as f:
    json.dump(data, f, indent=2)
"
ok "Registered marketplace: $MARKETPLACE"

# ── Install agents to ~/.claude/agents/ ─────────────────────────────
info "Installing agents ..."
mkdir -p "$AGENTS_DIR"
AGENT_COUNT=0
if [[ -d "$PLUGIN_CACHE/agents" ]]; then
    for agent_file in "$PLUGIN_CACHE/agents/"*.md; do
        [[ -f "$agent_file" ]] || continue
        agent_name="$(basename "$agent_file")"
        if [[ "$agent_name" != sdlc-* ]]; then
            agent_name="sdlc-${agent_name}"
        fi
        cp "$agent_file" "$AGENTS_DIR/$agent_name"
        AGENT_COUNT=$((AGENT_COUNT + 1))
    done
fi
ok "Installed $AGENT_COUNT agent(s)"

# ── Install rules ────────────────────────────────────────────────────
info "Installing rules ..."
mkdir -p "$RULES_DIR"
RULE_COUNT=0
if [[ -d "$PLUGIN_CACHE/rules" ]]; then
    for rule_file in "$PLUGIN_CACHE/rules/"*.md; do
        [[ -f "$rule_file" ]] || continue
        cp "$rule_file" "$RULES_DIR/"
        RULE_COUNT=$((RULE_COUNT + 1))
    done
fi
ok "Installed $RULE_COUNT rule(s)"

# ── Count commands and skills ───────────────────────────────────────
COMMAND_COUNT=$(find "$PLUGIN_CACHE/commands" -name "*.md" 2>/dev/null | wc -l)
SKILL_COUNT=$(find "$PLUGIN_CACHE/workflows" -name "SKILL.md" 2>/dev/null | wc -l)

# ── Summary ──────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}Installation complete!${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "  Source:      ${GREEN}$SCRIPT_DIR${NC}"
echo -e "  Installed:   ${GREEN}$PLUGIN_CACHE${NC}"
echo -e "  Config:      ${GREEN}$AG_HOME/config.yaml${NC}"
echo -e "  Plugin ID:   ${GREEN}${PLUGIN_ID}${NC}"
echo -e "  Commands:    ${GREEN}${COMMAND_COUNT} registered${NC}"
echo -e "  Skills:      ${GREEN}${SKILL_COUNT} available${NC}"
echo -e "  Agents:      ${GREEN}${AGENT_COUNT} installed${NC}"
echo -e "  Rules:       ${GREEN}${RULE_COUNT} installed${NC}"
echo ""
echo "Next steps:"
echo "  1. Restart Claude Code for the plugin to load"
echo "  2. Type /sdlc-init to start a new project"
echo "  3. Type /sdlc-ag-help for the full command reference"
echo ""
echo "Source repo at $SCRIPT_DIR is safe to modify — changes won't"
echo "affect the installed copy. Run ./setup again to reinstall."
echo ""
echo "To uninstall: $PLUGIN_CACHE/bin/sdlc-uninstall"
echo ""
