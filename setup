#!/usr/bin/env bash
set -euo pipefail

# Antigravity SDLC Framework — Claude Code Plugin Setup
# Converts the Antigravity Ultimate SDLC Framework for use with Claude Code.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AG_HOME="$HOME/.antigravity"
CLAUDE_DIR="$HOME/.claude"
SKILLS_DIR="$CLAUDE_DIR/skills"
AGENTS_DIR="$CLAUDE_DIR/agents"
RULES_DIR="$CLAUDE_DIR/rules/antigravity"
CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${BLUE}[info]${NC}  $*"; }
ok()    { echo -e "${GREEN}[ok]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[warn]${NC}  $*"; }
error() { echo -e "${RED}[error]${NC} $*"; }

echo ""
echo -e "${BOLD}Antigravity SDLC Framework — Claude Code Plugin Setup${NC}"
echo "======================================================"
echo ""

# ── Check prerequisites ──────────────────────────────────────────────
if ! command -v claude &>/dev/null; then
    warn "Claude Code CLI not found in PATH. The plugin will be installed but requires Claude Code to function."
fi

# ── Check if already installed ───────────────────────────────────────
if [[ -f "$AG_HOME/config.yaml" ]]; then
    warn "Antigravity is already installed (found $AG_HOME/config.yaml)."
    read -rp "Re-install? This will overwrite your config. [y/N] " answer
    if [[ "${answer,,}" != "y" ]]; then
        echo "Aborted."
        exit 0
    fi
fi

# ── Naming mode selection ────────────────────────────────────────────
echo "Select naming mode for workflow commands:"
echo ""
echo "  1) ${BOLD}Short names${NC} (default)"
echo "     /init, /planning-start, /dev-wave-1, /continue, etc."
echo ""
echo "  2) ${BOLD}Namespaced names${NC}"
echo "     /ag-init, /ag-planning-start, /ag-dev-wave-1, /ag-continue, etc."
echo ""
read -rp "Choice [1/2]: " naming_choice

NAMING_MODE="short"
if [[ "${naming_choice}" == "2" ]]; then
    NAMING_MODE="namespaced"
fi

info "Naming mode: ${BOLD}${NAMING_MODE}${NC}"
echo ""

# ── Create ~/.antigravity/ ───────────────────────────────────────────
info "Creating $AG_HOME/ ..."
mkdir -p "$AG_HOME"/{analytics,sessions}

cat > "$AG_HOME/config.yaml" <<EOF
# Antigravity SDLC Framework — Global Config
naming_mode: ${NAMING_MODE}
governance_mode: standard
project_type: web-app
telemetry: off
proactive: true
EOF
ok "Config written to $AG_HOME/config.yaml"

# ── Make bin/ scripts executable ─────────────────────────────────────
info "Making bin/ scripts executable ..."
chmod +x "$SCRIPT_DIR/bin/"* 2>/dev/null || true
ok "bin/ scripts are executable"

# ── Patch skill names based on naming mode ───────────────────────────
if [[ -x "$SCRIPT_DIR/bin/ag-patch-names" ]]; then
    info "Patching skill names for ${NAMING_MODE} mode ..."
    "$SCRIPT_DIR/bin/ag-patch-names"
    ok "Skill names patched"
fi

# ── Symlink workflow skills ──────────────────────────────────────────
info "Linking workflow skills ..."
WORKFLOW_COUNT=0
if [[ -d "$SCRIPT_DIR/workflows" ]]; then
    for wf_dir in "$SCRIPT_DIR/workflows"/*/; do
        [[ -d "$wf_dir" ]] || continue
        wf_name="$(basename "$wf_dir")"
        target="$SKILLS_DIR/$wf_name"
        if [[ -L "$target" ]]; then
            rm "$target"
        fi
        if [[ ! -e "$target" ]]; then
            ln -s "$wf_dir" "$target"
            ((WORKFLOW_COUNT++))
        else
            warn "Skipping $wf_name — directory already exists (not a symlink)"
        fi
    done
fi
ok "Linked $WORKFLOW_COUNT workflow skill(s)"

# ── Install agents ───────────────────────────────────────────────────
info "Installing agents ..."
mkdir -p "$AGENTS_DIR"
AGENT_COUNT=0
if [[ -d "$SCRIPT_DIR/agents" ]]; then
    for agent_file in "$SCRIPT_DIR/agents/"*.md; do
        [[ -f "$agent_file" ]] || continue
        agent_name="$(basename "$agent_file")"
        # Prefix with ag- if not already
        if [[ "$agent_name" != ag-* ]]; then
            agent_name="ag-${agent_name}"
        fi
        cp "$agent_file" "$AGENTS_DIR/$agent_name"
        ((AGENT_COUNT++))
    done
fi
ok "Installed $AGENT_COUNT agent(s)"

# ── Install rules ────────────────────────────────────────────────────
info "Installing rules ..."
mkdir -p "$RULES_DIR"
RULE_COUNT=0
if [[ -d "$SCRIPT_DIR/rules" ]]; then
    for rule_file in "$SCRIPT_DIR/rules/"*.md; do
        [[ -f "$rule_file" ]] || continue
        cp "$rule_file" "$RULES_DIR/"
        ((RULE_COUNT++))
    done
fi
ok "Installed $RULE_COUNT rule(s)"

# ── Append routing block to CLAUDE.md ────────────────────────────────
ROUTING_MARKER="## Antigravity SDLC Framework"
if [[ -f "$CLAUDE_MD" ]] && grep -qF "$ROUTING_MARKER" "$CLAUDE_MD"; then
    info "Routing block already present in CLAUDE.md — skipping"
else
    info "Appending routing block to $CLAUDE_MD ..."
    mkdir -p "$(dirname "$CLAUDE_MD")"
    cat >> "$CLAUDE_MD" <<'ROUTING_EOF'

## Antigravity SDLC Framework

### Available skills (Antigravity)

- `/init` — Initialize a new project with Antigravity SDLC
- `/adopt` — Onboard an existing codebase
- `/status` — Check current council/phase/gate progress
- `/continue` — Auto-advance to next step
- `/planning-start` — Begin Planning Council
- `/dev-start` — Begin Development Council
- `/audit-start` — Begin Audit Council
- `/validate-start` — Begin Validation Council
- `/new-cycle` — Start a new development cycle
- `/close-cycle` — Archive current cycle
- `/release` — Ship/release workflow
- `/ag-help` — Full command reference

Use `/antigravity` for framework overview and routing.
ROUTING_EOF
    ok "Routing block appended to CLAUDE.md"
fi

# ── Summary ──────────────────────────────────────────────────────────
echo ""
echo -e "${BOLD}Installation complete!${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "  Config:      ${GREEN}$AG_HOME/config.yaml${NC}"
echo -e "  Naming mode: ${GREEN}${NAMING_MODE}${NC}"
echo -e "  Workflows:   ${GREEN}${WORKFLOW_COUNT} linked${NC}"
echo -e "  Agents:      ${GREEN}${AGENT_COUNT} installed${NC}"
echo -e "  Rules:       ${GREEN}${RULE_COUNT} installed${NC}"
echo -e "  Plugin dir:  ${GREEN}$SCRIPT_DIR${NC}"
echo ""
echo "Next steps:"
echo "  1. Run /antigravity or /ag-help in Claude Code"
echo "  2. Run /init in a project directory to start"
echo ""
echo "To uninstall: $SCRIPT_DIR/bin/ag-uninstall"
echo ""
