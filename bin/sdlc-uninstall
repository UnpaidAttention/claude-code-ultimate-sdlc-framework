#!/usr/bin/env bash
set -euo pipefail

# sdlc-uninstall — Remove Ultimate SDLC Framework from Claude Code

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AG_HOME="$HOME/.ultimate-sdlc"
CLAUDE_DIR="$HOME/.claude"
SKILLS_DIR="$CLAUDE_DIR/skills"
AGENTS_DIR="$CLAUDE_DIR/agents"
RULES_DIR="$CLAUDE_DIR/rules/ultimate-sdlc"
CLAUDE_MD="$CLAUDE_DIR/CLAUDE.md"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${BLUE}[info]${NC}  $*"; }
ok()    { echo -e "${GREEN}[ok]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[warn]${NC}  $*"; }

echo ""
echo -e "${BOLD}Ultimate SDLC Framework — Uninstall${NC}"
echo "======================================="
echo ""

# ── Remove workflow symlinks ─────────────────────────────────────────
info "Removing workflow symlinks ..."
REMOVED=0
if [[ -d "$SCRIPT_DIR/workflows" ]]; then
    for wf_dir in "$SCRIPT_DIR/workflows"/*/; do
        [[ -d "$wf_dir" ]] || continue
        wf_name="$(basename "$wf_dir")"
        target="$SKILLS_DIR/$wf_name"
        if [[ -L "$target" ]]; then
            rm "$target"
            ((REMOVED++))
        fi
    done
fi
ok "Removed $REMOVED workflow symlink(s)"

# ── Remove agent files ───────────────────────────────────────────────
info "Removing agent files ..."
REMOVED=0
for agent_file in "$AGENTS_DIR"/sdlc-*.md; do
    [[ -f "$agent_file" ]] || continue
    rm "$agent_file"
    ((REMOVED++))
done
ok "Removed $REMOVED agent file(s)"

# ── Remove rules ────────────────────────────────────────────────────
info "Removing rules directory ..."
if [[ -d "$RULES_DIR" ]]; then
    rm -rf "$RULES_DIR"
    ok "Removed $RULES_DIR"
else
    ok "No rules directory to remove"
fi

# ── Remove routing block from CLAUDE.md ──────────────────────────────
info "Removing routing block from CLAUDE.md ..."
if [[ -f "$CLAUDE_MD" ]] && grep -qF "## Ultimate SDLC Framework" "$CLAUDE_MD"; then
    # Remove from the ## Ultimate SDLC Framework header to the next ## header or EOF
    # Use sed to delete the block
    sed -i '/^## Ultimate SDLC Framework$/,/^## [^A]/{/^## [^A]/!d}' "$CLAUDE_MD"
    # Also remove the marker line if it's now at EOF
    sed -i '/^## Ultimate SDLC Framework$/d' "$CLAUDE_MD"
    # Clean up trailing blank lines
    sed -i -e :a -e '/^\n*$/{$d;N;ba' -e '}' "$CLAUDE_MD"
    ok "Routing block removed from CLAUDE.md"
else
    ok "No routing block found in CLAUDE.md"
fi

# ── Optionally remove ~/.ultimate-sdlc/ ────────────────────────────────
echo ""
if [[ -d "$AG_HOME" ]]; then
    echo -e "${YELLOW}Found global config at $AG_HOME/${NC}"
    echo "This contains your global config, analytics, and session data."
    read -rp "Remove $AG_HOME/? [y/N] " answer
    if [[ "${answer,,}" == "y" ]]; then
        rm -rf "$AG_HOME"
        ok "Removed $AG_HOME/"
    else
        info "Kept $AG_HOME/ — remove manually if desired"
    fi
else
    ok "No global config to remove"
fi

echo ""
echo -e "${BOLD}Uninstall complete.${NC}"
echo ""
echo "Note: The plugin source at $SCRIPT_DIR/ was NOT removed."
echo "To fully remove, run: rm -rf $SCRIPT_DIR"
echo ""
